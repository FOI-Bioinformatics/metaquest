"""
Test visualization.reporting module functionality - comprehensive working tests.

Tests for PDF and HTML report generation with proper mocking of all dependencies.
"""

import tempfile
from pathlib import Path
from unittest.mock import Mock, patch, mock_open, MagicMock
import sys

import pytest
import pandas as pd

# Import the modules normally - we'll mock specific functions as needed
from metaquest.visualization.reporting import (
    generate_report,
    _create_title_page,
    _create_containment_summary_page,
    _add_metadata_summary_page,
    _add_correlation_heatmap,
    _generate_pdf_report,
    _prepare_template_data,
    _generate_plots_for_html,
    _create_default_template,
    _generate_html_report,
)
from metaquest.core.exceptions import VisualizationError


class TestGenerateReport:
    """Test main generate_report function."""

    def setup_method(self):
        """Reset any persistent state before each test."""
        pass

    def test_generate_report_pdf_basic(self, tmp_path):
        """Test basic PDF report generation."""
        summary_file = tmp_path / "summary.tsv"
        summary_data = pd.DataFrame({
            'max_containment': [0.95, 0.87, 0.12],
            'max_containment_annotation': ['Genome1', 'Genome2', 'Genome3'],
            'GCF_001': [0.95, 0.12, 0.05],
            'GCF_002': [0.23, 0.87, 0.12]
        }, index=['Sample1', 'Sample2', 'Sample3'])

        output_file = tmp_path / "test_report.pdf"

        with patch('pandas.read_csv', return_value=summary_data):
            with patch('metaquest.visualization.reporting._generate_pdf_report') as mock_pdf_gen:
                mock_pdf_gen.return_value = output_file
                
                result = generate_report(
                    title="Test Report",
                    summary_file=str(summary_file),
                    output_file=str(output_file),
                    format="pdf"
                )
        
        assert result == output_file
        mock_pdf_gen.assert_called_once()
        # Verify the call includes all required parameters
        call_kwargs = mock_pdf_gen.call_args[1]
        assert 'threshold' in call_kwargs
        assert 'include_plots' in call_kwargs
        assert 'include_tables' in call_kwargs

    def test_generate_report_html_with_jinja2(self, tmp_path):
        """Test HTML report generation with jinja2 available."""
        summary_file = tmp_path / "summary.tsv"
        summary_data = pd.DataFrame({
            'max_containment': [0.95, 0.87],
            'max_containment_annotation': ['Genome1', 'Genome2']
        }, index=['Sample1', 'Sample2'])

        output_file = tmp_path / "test_report.html"

        with patch('pandas.read_csv', return_value=summary_data):
            with patch('metaquest.visualization.reporting._generate_html_report') as mock_html_gen:
                with patch('metaquest.visualization.reporting.JINJA2_AVAILABLE', True):
                    mock_html_gen.return_value = output_file
                    
                    result = generate_report(
                        title="Test Report",
                        summary_file=str(summary_file),
                        output_file=str(output_file),
                        format="html"
                    )
        
        assert result == output_file
        mock_html_gen.assert_called_once()

    def test_generate_report_html_without_jinja2(self, tmp_path):
        """Test HTML report error when jinja2 not available."""
        summary_file = tmp_path / "summary.tsv"
        summary_data = pd.DataFrame({'max_containment': [0.95]})

        with patch('pandas.read_csv', return_value=summary_data):
            with patch('metaquest.visualization.reporting.JINJA2_AVAILABLE', False):
                with pytest.raises(VisualizationError, match="HTML report generation requires jinja2"):
                    generate_report(
                        title="Test",
                        summary_file=str(summary_file),
                        format="html"
                    )

    def test_generate_report_unsupported_format(self, tmp_path):
        """Test error for unsupported format."""
        summary_file = tmp_path / "summary.tsv"
        summary_data = pd.DataFrame({'max_containment': [0.95]})

        with patch('pandas.read_csv', return_value=summary_data):
            with pytest.raises(VisualizationError, match="Unsupported report format"):
                generate_report(
                    title="Test",
                    summary_file=str(summary_file),
                    format="xml"
                )

    def test_generate_report_with_all_files(self, tmp_path):
        """Test report generation with all optional files."""
        summary_file = tmp_path / "summary.tsv"
        metadata_file = tmp_path / "metadata.tsv"
        counts_file = tmp_path / "counts.tsv"
        
        summary_data = pd.DataFrame({'max_containment': [0.95]})
        metadata_data = pd.DataFrame({'organism': ['E. coli']})
        counts_data = pd.DataFrame({'category': ['bacteria'], 'count': [100]})

        # Mock file existence and reading
        with patch('pandas.read_csv', side_effect=[summary_data, metadata_data, counts_data]):
            with patch('pathlib.Path.exists', return_value=True):
                with patch('metaquest.visualization.reporting._generate_pdf_report') as mock_pdf_gen:
                    mock_pdf_gen.return_value = "output.pdf"
                    
                    result = generate_report(
                        title="Complete Report",
                        summary_file=str(summary_file),
                        metadata_file=str(metadata_file),
                        metadata_counts_file=str(counts_file),
                        threshold=0.05,
                        include_plots=True,
                        include_tables=True
                    )
        
        # Verify all data was passed to PDF generator
        call_kwargs = mock_pdf_gen.call_args[1]
        assert call_kwargs['metadata_data'] is not None
        assert call_kwargs['counts_data'] is not None

    def test_generate_report_file_read_error(self, tmp_path):
        """Test error handling when file reading fails."""
        summary_file = tmp_path / "summary.tsv"
        
        with patch('pandas.read_csv', side_effect=Exception("File read error")):
            with pytest.raises(VisualizationError, match="Error generating report"):
                generate_report(
                    title="Test",
                    summary_file=str(summary_file)
                )


class TestCreateTitlePage:
    """Test _create_title_page function."""

    def test_create_title_page_with_metadata(self):
        """Test title page creation with metadata."""
        mock_fig = Mock()
        mock_ax = Mock()
        
        summary_data = "test_summary.tsv"  # Function expects path string
        metadata_data = pd.DataFrame({'col1': [1, 2, 3]})
        
        with patch('matplotlib.pyplot.subplots', return_value=(mock_fig, mock_ax)):
            with patch('metaquest.visualization.reporting.datetime') as mock_dt:
                mock_dt.now.return_value.strftime.return_value = "2023-01-01 12:00"
                
                result = _create_title_page("Test Title", summary_data, metadata_data)
        
        assert result == mock_fig
        mock_ax.text.assert_called()
        assert mock_ax.text.call_count >= 4  # Title, subtitle, date, metadata info

    def test_create_title_page_without_metadata(self):
        """Test title page creation without metadata."""
        mock_fig = Mock()
        mock_ax = Mock()
        
        summary_data = "test_summary.tsv"
        
        with patch('matplotlib.pyplot.subplots', return_value=(mock_fig, mock_ax)):
            with patch('metaquest.visualization.reporting.datetime') as mock_dt:
                mock_dt.now.return_value.strftime.return_value = "2023-01-01 12:00"
                
                result = _create_title_page("Test Title", summary_data, None)
        
        assert result == mock_fig
        mock_ax.text.assert_called()


class TestCreateContainmentSummaryPage:
    """Test _create_containment_summary_page function."""

    def test_containment_summary_page_basic(self):
        """Test basic containment summary page creation."""
        mock_fig = Mock()
        mock_ax = Mock()
        
        summary_data = pd.DataFrame({
            'max_containment': [0.95, 0.87, 0.12, 0.05],
            'max_containment_annotation': ['Genome1', 'Genome2', 'Genome3', 'Genome4'],
            'GCF_001': [0.95, 0.12, 0.05, 0.01],
            'GCF_002': [0.23, 0.87, 0.12, 0.05]
        }, index=['Sample1', 'Sample2', 'Sample3', 'Sample4'])
        
        with patch('matplotlib.pyplot.subplots', return_value=(mock_fig, mock_ax)):
            fig, filtered_samples = _create_containment_summary_page(summary_data, threshold=0.1)
        
        assert fig == mock_fig
        assert len(filtered_samples) == 3  # Samples above 0.1 threshold
        mock_ax.text.assert_called()
        mock_ax.table.assert_called_once()

    def test_containment_summary_page_no_samples_above_threshold(self):
        """Test when no samples above threshold."""
        mock_fig = Mock()
        mock_ax = Mock()
        # Mock matplotlib at method level
        with patch('matplotlib.pyplot.subplots', return_value=(mock_fig, mock_ax)):
            summary_data = pd.DataFrame({
                'max_containment': [0.05, 0.03],
                'max_containment_annotation': ['Genome1', 'Genome2'],
                'GCF_001': [0.05, 0.03]
            }, index=['Sample1', 'Sample2'])
            
            fig, filtered_samples = _create_containment_summary_page(summary_data, threshold=0.1)
            
            assert len(filtered_samples) == 0


class TestAddMetadataSummaryPage:
    """Test _add_metadata_summary_page function."""

    def test_add_metadata_summary_page_success(self):
        """Test metadata summary page addition."""
        mock_pdf = Mock()
        mock_fig = Mock()
        mock_ax = Mock()
        
        metadata_data = pd.DataFrame({
            'organism': ['E. coli', 'S. enterica', None],
            'country': ['USA', 'Denmark', 'UK'],
            'assay_type': ['WGS', None, 'WGS']
        })
        
        with patch('matplotlib.pyplot.subplots', return_value=(mock_fig, mock_ax)) as mock_subplots:
            with patch('matplotlib.pyplot.close'):
                _add_metadata_summary_page(mock_pdf, metadata_data)
        
        mock_subplots.assert_called_with(figsize=(8.5, 11))
        mock_pdf.savefig.assert_called_once_with(mock_fig)
        mock_ax.table.assert_called_once()

    def test_add_metadata_summary_page_empty_data(self):
