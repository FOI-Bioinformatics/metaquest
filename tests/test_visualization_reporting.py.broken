"""
Tests for metaquest.visualization.reporting module.
"""

import pytest
import pandas as pd
from pathlib import Path
from unittest.mock import Mock, patch, MagicMock, mock_open
import tempfile

from metaquest.core.exceptions import VisualizationError
from metaquest.visualization.reporting import (
    generate_report,
    _create_title_page,
    _create_containment_summary_page,
    _add_metadata_summary_page,
    _add_correlation_heatmap,
    _generate_pdf_report,
    _prepare_template_data,
    _generate_plots_for_html,
    _create_default_template,
    _generate_html_report,
)


class TestGenerateReport:
    """Test generate_report function."""

    def test_generate_report_pdf_success(self, tmp_path):
        """Test successful PDF report generation."""
        summary_file = tmp_path / "summary.csv"
        output_file = tmp_path / "report.pdf"
        
        # Create test data
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87],
            "sample_count": [10, 8]
        })
        summary_data.to_csv(summary_file, index=False)
        
        with patch('metaquest.visualization.reporting._generate_pdf_report') as mock_pdf:
            mock_pdf.return_value = str(output_file)
            
            result = generate_report(
                title="Test Report",
                summary_file=summary_file,
                output_file=output_file,
                format="pdf"
            )
        
        assert result == str(output_file)
        mock_pdf.assert_called_once()

    def test_generate_report_html_success(self, tmp_path):
        """Test successful HTML report generation."""
        summary_file = tmp_path / "summary.csv"
        output_file = tmp_path / "report.html"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87]
        })
        summary_data.to_csv(summary_file, index=False)
        
        with patch('metaquest.visualization.reporting._generate_html_report') as mock_html:
            mock_html.return_value = str(output_file)
            
            result = generate_report(
                title="Test Report",
                summary_file=summary_file,
                output_file=output_file,
                format="html"
            )
        
        assert result == str(output_file)
        mock_html.assert_called_once()

    def test_generate_report_unsupported_format(self, tmp_path):
        """Test error handling for unsupported formats."""
        summary_file = tmp_path / "summary.csv"
        
        pd.DataFrame({"test": [1, 2]}).to_csv(summary_file, index=False)
        
        with pytest.raises(VisualizationError, match="Unsupported report format"):
            generate_report(
                title="Test",
                summary_file=summary_file,
                format="xml"
            )

    def test_generate_report_missing_summary_file(self, tmp_path):
        """Test error handling for missing summary file."""
        nonexistent_file = tmp_path / "nonexistent.csv"
        
        with pytest.raises(VisualizationError):
            generate_report(
                title="Test",
                summary_file=nonexistent_file,
                format="pdf"
            )

    def test_generate_report_with_metadata(self, tmp_path):
        """Test report generation with metadata file."""
        summary_file = tmp_path / "summary.csv"
        metadata_file = tmp_path / "metadata.csv"
        output_file = tmp_path / "report.pdf"
        
        pd.DataFrame({"accession": ["SRR123"], "max_containment": [0.95]}).to_csv(summary_file, index=False)
        pd.DataFrame({"Run_ID": ["SRR123"], "organism": ["E. coli"]}).to_csv(metadata_file, index=False)
        
        with patch('metaquest.visualization.reporting._generate_pdf_report') as mock_pdf:
            mock_pdf.return_value = str(output_file)
            
            generate_report(
                title="Test Report",
                summary_file=summary_file,
                metadata_file=metadata_file,
                output_file=output_file
            )
        
        # Verify metadata was passed to PDF generator
        call_args = mock_pdf.call_args[0]
        assert call_args[2] is not None  # metadata_data argument

    def test_generate_report_no_plots_no_tables(self, tmp_path):
        """Test report generation with plots and tables disabled."""
        summary_file = tmp_path / "summary.csv"
        output_file = tmp_path / "report.pdf"
        
        pd.DataFrame({"accession": ["SRR123"], "max_containment": [0.95]}).to_csv(summary_file, index=False)
        
        with patch('metaquest.visualization.reporting._generate_pdf_report') as mock_pdf:
            mock_pdf.return_value = str(output_file)
            
            generate_report(
                title="Test Report",
                summary_file=summary_file,
                output_file=output_file,
                include_plots=False,
                include_tables=False
            )
        
        mock_pdf.assert_called_once()


class TestCreateTitlePage:
    """Test _create_title_page function."""

    def test_create_title_page_with_data(self):
        """Test title page creation with summary and metadata."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456", "SRR789"],
            "max_containment": [0.95, 0.87, 0.92]
        })
        metadata_data = pd.DataFrame({
            "Run_ID": ["SRR123", "SRR456"],
            "organism": ["E. coli", "S. aureus"]
        })
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _create_title_page("Test Analysis Report", summary_data, metadata_data)
        
        mock_fig.assert_called_once()

    def test_create_title_page_no_metadata(self):
        """Test title page creation without metadata."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87]
        })
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _create_title_page("Test Report", summary_data, None)
        
        mock_fig.assert_called_once()

    def test_create_title_page_empty_data(self):
        """Test title page creation with empty data."""
        empty_data = pd.DataFrame()
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _create_title_page("Empty Report", empty_data, None)
        
        mock_fig.assert_called_once()


class TestCreateContainmentSummaryPage:
    """Test _create_containment_summary_page function."""

    def test_create_containment_summary_page_success(self):
        """Test containment summary page creation."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456", "SRR789"],
            "max_containment": [0.95, 0.87, 0.92],
            "sample_count": [10, 8, 9]
        })
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            with patch('metaquest.visualization.plots.plot_containment') as mock_plot:
                mock_fig.return_value = MagicMock()
                
                _create_containment_summary_page(summary_data, threshold=0.9)
        
        mock_fig.assert_called_once()
        mock_plot.assert_called_once()

    def test_create_containment_summary_page_no_high_containment(self):
        """Test page creation when no samples exceed threshold."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.75, 0.68]
        })
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _create_containment_summary_page(summary_data, threshold=0.9)
        
        mock_fig.assert_called_once()


class TestAddMetadataSummaryPage:
    """Test _add_metadata_summary_page function."""

    def test_add_metadata_summary_page_success(self):
        """Test metadata summary page addition."""
        metadata_data = pd.DataFrame({
            "Run_ID": ["SRR123", "SRR456", "SRR789"],
            "organism": ["E. coli", "S. aureus", "B. subtilis"],
            "collection_date": ["2020-01-01", "2020-02-01", "2020-03-01"]
        })
        
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _add_metadata_summary_page(mock_pdf, metadata_data)
        
        mock_fig.assert_called()
        mock_pdf.savefig.assert_called()

    def test_add_metadata_summary_page_empty_data(self):
        """Test with empty metadata."""
        empty_metadata = pd.DataFrame()
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _add_metadata_summary_page(mock_pdf, empty_metadata)
        
        mock_fig.assert_called_once()

    def test_add_metadata_summary_page_single_column(self):
        """Test with metadata having only one informative column."""
        metadata_data = pd.DataFrame({
            "Run_ID": ["SRR123", "SRR456"],
            "organism": ["E. coli", "E. coli"]  # Same value
        })
        
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            mock_fig.return_value = MagicMock()
            
            _add_metadata_summary_page(mock_pdf, metadata_data)
        
        mock_fig.assert_called()


class TestAddCorrelationHeatmap:
    """Test _add_correlation_heatmap function."""

    def test_add_correlation_heatmap_success(self):
        """Test correlation heatmap addition."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87],
            "sample_count": [10, 8],
            "avg_quality": [35.5, 33.2]
        })
        
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.reporting.plt.figure') as mock_fig:
            with patch('metaquest.visualization.plots.plot_correlation_matrix') as mock_plot:
                mock_fig.return_value = MagicMock()
                
                _add_correlation_heatmap(mock_pdf, summary_data, threshold=0.9)
        
        mock_plot.assert_called_once()
        mock_pdf.savefig.assert_called()

    def test_add_correlation_heatmap_insufficient_numeric_columns(self):
        """Test when insufficient numeric columns for correlation."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87]  # Only one numeric column
        })
        
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.reporting.logger') as mock_logger:
            _add_correlation_heatmap(mock_pdf, summary_data, threshold=0.9)
        
        mock_logger.info.assert_called_with("Insufficient numeric columns for correlation analysis")

    def test_add_correlation_heatmap_plot_error(self):
        """Test error handling in correlation plotting."""
        summary_data = pd.DataFrame({
            "max_containment": [0.95, 0.87],
            "sample_count": [10, 8]
        })
        
        mock_pdf = MagicMock()
        
        with patch('metaquest.visualization.plots.plot_correlation_matrix', side_effect=Exception("Plot error")):
            with patch('metaquest.visualization.reporting.logger') as mock_logger:
                _add_correlation_heatmap(mock_pdf, summary_data, threshold=0.9)
        
        mock_logger.error.assert_called()


class TestGeneratePdfReport:
    """Test _generate_pdf_report function."""

    def test_generate_pdf_report_full_features(self, tmp_path):
        """Test PDF generation with all features enabled."""
        output_file = tmp_path / "report.pdf"
        title = "Comprehensive Analysis Report"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87],
            "sample_count": [10, 8]
        })
        
        metadata_data = pd.DataFrame({
            "Run_ID": ["SRR123", "SRR456"],
            "organism": ["E. coli", "S. aureus"]
        })
        
        with patch('metaquest.visualization.reporting.PdfPages') as mock_pdf_pages:
            mock_pdf = MagicMock()
            mock_pdf_pages.return_value.__enter__.return_value = mock_pdf
            
            with patch('metaquest.visualization.reporting._create_title_page') as mock_title:
                with patch('metaquest.visualization.reporting._create_containment_summary_page') as mock_summary:
                    with patch('metaquest.visualization.reporting._add_metadata_summary_page') as mock_metadata:
                        with patch('metaquest.visualization.reporting._add_correlation_heatmap') as mock_correlation:
                            
                            result = _generate_pdf_report(
                                title, summary_data, metadata_data, None, 
                                output_file, threshold=0.9, 
                                include_plots=True, include_tables=True
                            )
        
        assert result == str(output_file)
        mock_title.assert_called_once()
        mock_summary.assert_called_once()
        mock_metadata.assert_called_once()
        mock_correlation.assert_called_once()

    def test_generate_pdf_report_minimal(self, tmp_path):
        """Test PDF generation with minimal features."""
        output_file = tmp_path / "minimal_report.pdf"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123"],
            "max_containment": [0.95]
        })
        
        with patch('metaquest.visualization.reporting.PdfPages') as mock_pdf_pages:
            mock_pdf = MagicMock()
            mock_pdf_pages.return_value.__enter__.return_value = mock_pdf
            
            with patch('metaquest.visualization.reporting._create_title_page') as mock_title:
                
                result = _generate_pdf_report(
                    "Minimal Report", summary_data, None, None,
                    output_file, threshold=0.9,
                    include_plots=False, include_tables=False
                )
        
        assert result == str(output_file)
        mock_title.assert_called_once()


class TestPrepareTemplateData:
    """Test _prepare_template_data function."""

    def test_prepare_template_data_complete(self):
        """Test template data preparation with complete data."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456", "SRR789"],
            "max_containment": [0.95, 0.87, 0.92],
            "sample_count": [10, 8, 9]
        })
        
        metadata_data = pd.DataFrame({
            "Run_ID": ["SRR123", "SRR456"],
            "organism": ["E. coli", "S. aureus"]
        })
        
        counts_data = pd.DataFrame({
            "organism": ["E. coli", "S. aureus"],
            "count": [15, 8]
        })
        
        result = _prepare_template_data(
            "Test Analysis", summary_data, metadata_data, counts_data, 0.9
        )
        
        assert result["title"] == "Test Analysis"
        assert result["threshold"] == 0.9
        assert result["total_samples"] == 3
        assert result["high_containment_samples"] == 2  # Above 0.9 threshold
        assert "summary_stats" in result
        assert "metadata_available" in result

    def test_prepare_template_data_minimal(self):
        """Test template data preparation with minimal data."""
        summary_data = pd.DataFrame({
            "accession": ["SRR123"],
            "max_containment": [0.75]
        })
        
        result = _prepare_template_data(
            "Minimal Analysis", summary_data, None, None, 0.9
        )
        
        assert result["title"] == "Minimal Analysis"
        assert result["total_samples"] == 1
        assert result["high_containment_samples"] == 0
        assert result["metadata_available"] is False

    def test_prepare_template_data_empty_summary(self):
        """Test with empty summary data."""
        empty_summary = pd.DataFrame()
        
        result = _prepare_template_data(
            "Empty Analysis", empty_summary, None, None, 0.9
        )
        
        assert result["total_samples"] == 0
        assert result["high_containment_samples"] == 0


class TestGeneratePlotsForHtml:
    """Test _generate_plots_for_html function."""

    def test_generate_plots_for_html_success(self, tmp_path):
        """Test HTML plot generation."""
        images_dir = tmp_path / "images"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87]
        })
        
        counts_data = pd.DataFrame({
            "organism": ["E. coli", "S. aureus"],
            "count": [10, 5]
        })
        
        with patch('metaquest.visualization.plots.plot_containment') as mock_plot_contain:
            with patch('metaquest.visualization.plots.plot_metadata_counts') as mock_plot_counts:
                with patch('metaquest.visualization.reporting.plt.savefig') as mock_savefig:
                    
                    result = _generate_plots_for_html(summary_data, counts_data, 0.9, images_dir)
        
        assert isinstance(result, dict)
        assert "containment_plot" in result
        mock_plot_contain.assert_called()
        if counts_data is not None:
            mock_plot_counts.assert_called()

    def test_generate_plots_for_html_no_counts(self, tmp_path):
        """Test HTML plot generation without counts data."""
        images_dir = tmp_path / "images"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123"],
            "max_containment": [0.95]
        })
        
        with patch('metaquest.visualization.plots.plot_containment') as mock_plot:
            with patch('metaquest.visualization.reporting.plt.savefig') as mock_savefig:
                
                result = _generate_plots_for_html(summary_data, None, 0.9, images_dir)
        
        assert "containment_plot" in result
        assert "counts_plot" not in result


class TestCreateDefaultTemplate:
    """Test _create_default_template function."""

    def test_create_default_template(self):
        """Test default template creation."""
        template = _create_default_template()
        
        assert isinstance(template, str)
        assert "<!DOCTYPE html>" in template
        assert "{{ title }}" in template
        assert "{{ total_samples }}" in template
        assert "{{ high_containment_samples }}" in template

    def test_create_default_template_structure(self):
        """Test that template has required sections."""
        template = _create_default_template()
        
        # Check for major sections
        assert "<head>" in template
        assert "<body>" in template
        assert "MetaQuest Analysis Report" in template
        assert "{% if plots %}" in template
        assert "{% if metadata_available %}" in template


class TestGenerateHtmlReport:
    """Test _generate_html_report function."""

    @patch('metaquest.visualization.reporting.JINJA2_AVAILABLE', True)
    def test_generate_html_report_with_jinja2(self, tmp_path):
        """Test HTML report generation with jinja2 available."""
        output_file = tmp_path / "report.html"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123", "SRR456"],
            "max_containment": [0.95, 0.87]
        })
        
        with patch('jinja2.Template') as mock_template_class:
            mock_template = MagicMock()
            mock_template.render.return_value = "<html>Test Report</html>"
            mock_template_class.return_value = mock_template
            
            with patch('metaquest.visualization.reporting._prepare_template_data') as mock_prepare:
                with patch('metaquest.visualization.reporting._generate_plots_for_html') as mock_plots:
                    mock_prepare.return_value = {"title": "Test Report"}
                    mock_plots.return_value = {"containment_plot": "plot1.png"}
                    
                    result = _generate_html_report(
                        "Test Report", summary_data, None, None,
                        output_file, threshold=0.9,
                        include_plots=True, include_tables=True
                    )
        
        assert result == str(output_file)
        assert output_file.exists()

    @patch('metaquest.visualization.reporting.JINJA2_AVAILABLE', False)
    def test_generate_html_report_without_jinja2(self, tmp_path):
        """Test HTML report generation without jinja2."""
        output_file = tmp_path / "report.html"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123"],
            "max_containment": [0.95]
        })
        
        with patch('metaquest.visualization.reporting._create_default_template') as mock_template:
            mock_template.return_value = "Basic HTML: {{ title }}"
            
            result = _generate_html_report(
                "Basic Report", summary_data, None, None,
                output_file, threshold=0.9
            )
        
        assert result == str(output_file)
        assert output_file.exists()

    def test_generate_html_report_plot_generation_error(self, tmp_path):
        """Test error handling in plot generation for HTML."""
        output_file = tmp_path / "report.html"
        
        summary_data = pd.DataFrame({
            "accession": ["SRR123"],
            "max_containment": [0.95]
        })
        
        with patch('metaquest.visualization.reporting._generate_plots_for_html', side_effect=Exception("Plot error")):
            with patch('metaquest.visualization.reporting.logger') as mock_logger:
                
                result = _generate_html_report(
                    "Error Test", summary_data, None, None,
                    output_file, include_plots=True
                )
        
        mock_logger.error.assert_called()
        assert result == str(output_file)


if __name__ == "__main__":
    pytest.main([__file__])